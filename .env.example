# Telegram-бот (опционально). Для чистого веба: BOT_ENABLED=false, BOT_TOKEN можно не задавать.
BOT_ENABLED=false
BOT_TOKEN=
# Таймаут HTTP к api.telegram.org (сек), при медленной сети / Docker
# TELEGRAM_REQUEST_TIMEOUT=120
# Прокси к Telegram, если API недоступен (формат aiohttp, напр. http://user:pass@host:8080)
# TELEGRAM_PROXY=
# Заявка на ФЭБарт со страницы участника /cabinet/request (по умолчанию выкл.)
# WEB_BALANCE_REQUEST_ENABLED=false
# Максимум ФЭБарт в одной заявке /request в боте
# MAX_BALANCE_REQUEST_FEB=5000

# SQLite (локально: файл в каталоге проекта; в Docker задаётся в docker-compose)
DATABASE_URL=sqlite+aiosqlite:///./febnik.db

# --- Веб-панель (http://хост:порт) ---
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
# Только Docker Compose: порт на хосте (по умолчанию в compose — 8001; внутри контейнера 8080)
WEB_PUBLISH_PORT=8001
# Ссылка для текста в боте (укажите http://<хост>:<порт> как с телефона/ноутбука)
WEB_PUBLIC_BASE_URL=https://febnik.ru
WEB_COOKIE_SECURE=true
# Каталог для картинок плашки кабинета (дни 1–3). В Docker см. CABINET_BANNERS_DIR в compose.
# CABINET_BANNERS_DIR=uploads/cabinet_banners

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong
SESSION_SECRET=replace-with-long-random-string

# Почта: код входа участника (/join). Пустой SMTP_HOST — код только в лог сервера (dev).
# две плашки 
# --- Gmail (Google Почта) ---
# Хост и порт по умолчанию уже подходят: STARTTLS на 587.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_STARTTLS=true
# SMTP_USER=anatolii.kozmin@gmail.com
# SMTP_FROM=anatolii.kozmin@gmail.com
# Пароль обычного входа Gmail не подойдёт: включите 2FA и создайте «Пароль приложения»
# (аккаунт Google → Безопасность → двухэтапная аутентификация → пароли приложений).
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# На VPS часто не работает исходящий IPv6 к Gmail — включите, если таймаут/нет письма:
# SMTP_PREFER_IPV4=true
# Если 587 «висит», попробуйте Gmail на 465 (TLS сразу), в .env:
# SMTP_PORT=465
# SMTP_STARTTLS=false
# SMTP_IMPLICIT_SSL=true
# SMTP_PREFER_IPV4=true
#
# JOIN_OTP_TTL_SECONDS=600
# JOIN_OTP_RESEND_SECONDS=60
# Срок «запоминания» входа по почте (подписанная cookie febnik_p), по умолчанию ~10 лет
# PARTICIPANT_TOKEN_MAX_AGE_SECONDS=315360000
# За HTTPS в проде: cookie только по TLS
# WEB_COOKIE_SECURE=false

# Telegram ID через запятую — оргкомитет: /sync (Google), /export в Sheets
ORG_TELEGRAM_IDS=

# Стойка призов (/handout). Если пусто — те же ID, что ORG_TELEGRAM_IDS
HANDOUT_TELEGRAM_IDS=

# --- Опционально: Google Sheets (pip install gspread google-auth) ---
# GOOGLE_CREDENTIALS_PATH=./service_account.json
# GOOGLE_SPREADSHEET_ID=
# SHEET_ACTIVITIES=Интерактивы
# SHEET_PRIZES=Призы
# SHEET_LOG=Лог_операций
# SHEET_FEEDBACK_TAB_PREFIX=ОС день
